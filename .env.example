SECRET_KEY=change-me-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,votre-domaine.onrender.com
CSRF_TRUSTED_ORIGINS=https://votre-domaine.onrender.com

# SQLite en developpement local, PostgreSQL en production.
DATABASE_URL=sqlite:///db.sqlite3
# Exemple PostgreSQL:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# Fournisseur LLM: openai, groq ou gemini.
LLM_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# RAG local.
CHROMA_PERSIST_DIRECTORY=./chroma_db
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Securite / production.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Limites applicatives.
MAX_UPLOAD_SIZE_MB=10
MAX_CHAT_QUESTION_LENGTH=1200
RAG_MIN_RELEVANCE_SCORE=0.25
CHAT_RATE_LIMIT_COUNT=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=3600
